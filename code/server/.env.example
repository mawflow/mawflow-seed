# 服务端环境变量示例
# 应用环境；本地为 local，远程测试为 test，生产为 production。
APP_ENV=local
# 应用名称；初始化项目时替换 project_key。
APP_NAME={ project_key }-server
# 服务端本地访问地址。
APP_URL=http://localhost:8000
# API 对外基础地址；前端联调会引用。
API_BASE_URL=http://localhost:8000/api
# 数据库类型；按项目实际技术栈填写，例如 sqlite、pgsql 或 mysql。
DB_CONNECTION=<sqlite|pgsql|mysql>
# 数据库主机；AI 调试可在 .maw/secrets.yaml 的 app_debug.apps.server.database.dev 中显式镜像。
DB_HOST=127.0.0.1
# 数据库端口；SQLite 可留空。
DB_PORT=<port>
# 数据库名称或文件路径。
DB_DATABASE=<database_name>
# 数据库用户名；SQLite 可留空。
DB_USERNAME=<username>
# 数据库密码；真实值可在 code 内本地 .env 或 .maw/secrets*.yaml 的 AI 调试区维护。
DB_PASSWORD=<REDACTED>
